{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/chart-request.schema.json",
  "title": "Codex Chart Request",
  "type": "object",
  "required": [
    "request_version",
    "output",
    "chart",
    "data_source",
    "mapping"
  ],
  "properties": {
    "request_version": {
      "type": "string",
      "default": "1.0"
    },
    "output": {
      "type": "object",
      "required": ["format", "container_id"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["html", "csv", "xlsx"]
        },
        "container_id": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 100
        },
        "height": {
          "type": "integer",
          "minimum": 100
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "auto"]
        }
      },
      "additionalProperties": true
    },
    "chart": {
      "type": "object",
      "required": ["type", "title", "show_legend"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["line", "bar", "pie", "scatter"]
        },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "show_legend": { "type": "boolean" },
        "show_grid": { "type": "boolean" },
        "x_axis_label": { "type": "string" },
        "y_axis_label": { "type": "string" },
        "stacked": { "type": "boolean" },
        "grid_style": {
          "type": "object",
          "properties": {
            "color": { "type": "string" },
            "width": { "type": "number", "minimum": 0.1, "maximum": 10 },
            "dash_pattern": { "type": "array", "items": { "type": "number" } }
          },
          "additionalProperties": false
        },
        "show_data_labels": { "type": "boolean" },
        "legend_position": {
          "type": "string",
          "enum": ["top", "bottom", "left", "right"]
        },
        "animation_duration": { "type": "integer", "minimum": 0 },
        "y_axis_min": { "type": "number" },
        "y_axis_max": { "type": "number" }
      },
      "additionalProperties": true
    },
    "data_source": {
      "type": "object",
      "required": ["proc_schema", "proc_name", "result_set_index"],
      "properties": {
        "proc_schema": { "type": "string", "default": "ri" },
        "proc_name": { "type": "string" },
        "endpoint": { "type": "string" },
        "http_method": { "type": "string", "enum": ["GET", "POST"] },
        "proc_params": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        },
        "result_set_index": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "mapping": {
      "type": "object",
      "properties": {
        "xField": { "type": "string" },
        "yField": { "type": "string" },
        "groupField": { "type": "string" },
        "categoryField": { "type": "string" },
        "valueField": { "type": "string" },
        "labelTemplate": { "type": "string" },
        "x_axis_tick_format": { "type": "string", "description": "Optional format hint for x-axis ticks: 'abbreviated_month' for month start labels, or other date format directives." }
      },
      "additionalProperties": true
    },
    "options": {
      "type": "object",
      "properties": {
        "tension": { "type": "number", "minimum": 0, "maximum": 1 },
        "pointRadius": { "type": "integer", "minimum": 0 },
        "pointHoverRadius": { "type": "integer", "minimum": 0 },
        "borderWidth": { "type": "number", "minimum": 0 },
        "fill": { "type": "boolean" },
        "stacked": { "type": "boolean" },
        "indexAxis": { "type": "string", "enum": ["x", "y"] },
        "border_radius": { "type": "integer", "minimum": 0 },
        "point_style": {
          "type": "string",
          "enum": ["circle", "cross", "crossRot", "dash", "line", "rect", "rectRot", "star", "triangle"]
        }
      },
      "additionalProperties": true
    },
    "appearance": {
      "type": "object",
      "properties": {
        "page_background": { "type": "string" },
        "card_background": { "type": "string" },
        "title_color": { "type": "string" },
        "text_color": { "type": "string" },
        "axis_color": { "type": "string" },
        "grid_color": { "type": "string" },
        "x_axis_label_color": { "type": "string" },
        "x_axis_value_color": { "type": "string" },
        "y_axis_label_color": { "type": "string" },
        "y_axis_value_color": { "type": "string" },
        "legend_text_color": { "type": "string" },
        "grid_style": {
          "type": "object",
          "properties": {
            "color": { "type": "string" },
            "width": { "type": "number", "minimum": 0.1, "maximum": 10 },
            "dash_pattern": { "type": "array", "items": { "type": "number" } }
          },
          "additionalProperties": false
        },
        "series_colors": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    },
    "export_options": {
      "type": "object",
      "properties": {
        "column_order": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "include_remaining_columns": {
          "type": "boolean",
          "default": true
        },
        "xlsx": {
          "type": "object",
          "properties": {
            "sheet_name": { "type": "string" },
            "template_path": { "type": "string" },
            "template_sheet_name": { "type": "string" },
            "result_set_indices": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0 },
              "minItems": 1
            },
            "sheet_names": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "sheet_name_prefix": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
