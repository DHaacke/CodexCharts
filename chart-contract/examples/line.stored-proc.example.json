{
  "request_version": "1.0",
  "output": {
    "format": "html",
    "container_id": "chart-root"
  },
  "chart": {
    "type": "line",
    "title": "FWP Survey Species by Year",
    "show_legend": true,
    "x_axis_label": "Year",
    "y_axis_label": "Abundance",
    "stacked": false
  },
  "data_source": {
    "proc_schema": "ri",
    "proc_name": "FWPSpeciesCountByYear",
    "endpoint": "http://localhost:3000/api/stored-proc",
    "http_method": "GET",
    "proc_params": {
      "from_year": "2024",
      "to_year": "2026"
    },
    "result_set_index": 0
  },
  "mapping": {
    "xField": "year",
    "yField": "abundance",
    "groupField": "species"
  },
  "options": {
    "tension": 0.2,
    "pointRadius": 2
  }
}
