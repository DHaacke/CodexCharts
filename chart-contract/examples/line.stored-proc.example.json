{
  "request_version": "1.0",
  "output": {
    "format": "html",
    "container_id": "chart-root",
    "width": 1180,
    "height": 680
  },
  "chart": {
    "type": "line",
    "title": "{species} {from_year}-{to_year} Survey by Year",
    "show_legend": true,
    "x_axis_label": "Year",
    "y_axis_label": "Abundance",
    "stacked": false
  },
  "data_source": {
    "proc_schema": "ri",
    "proc_name": "FWPSpeciesCountByYear",
    "endpoint": "http://localhost:3000/api/stored-proc",
    "http_method": "GET",
    "proc_params": {
      "from_year": "2024",
      "to_year": "2026"
    },
    "result_set_index": 0
  },
  "mapping": {
    "xField": "year",
    "yField": "abundance",
    "groupField": "species"
  },
  "options": {
    "tension": 0.2,
    "pointRadius": 2
  },
  "appearance": {
    "page_background": "linear-gradient(145deg, #d7e7df, #bfd6ce)",
    "card_background": "rgba(243,250,246,0.82)",
    "title_color": "#184f3f",
    "text_color": "#2f6f5d",
    "grid_color": "rgba(24,79,63,0.2)",
    "x_axis_label_color": "#184f3f",
    "x_axis_value_color": "#2f6f5d",
    "y_axis_label_color": "#184f3f",
    "y_axis_value_color": "#2f6f5d",
    "legend_text_color": "#184f3f",
    "series_colors": ["#2b8cbe", "#f28e2b", "#59a14f", "#af7aa1"]
  }
}
