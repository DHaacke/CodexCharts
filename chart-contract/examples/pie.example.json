{
  "request_version": "1.0",
  "output": {
    "format": "html",
    "container_id": "chart-root",
    "width": 1100,
    "height": 680
  },
  "chart": {
    "type": "pie",
    "title": "{species} {from_year}-{to_year} Abundance Share",
    "show_legend": true,
    "x_axis_label": "",
    "y_axis_label": ""
  },
  "data_source": {
    "proc_schema": "ri",
    "proc_name": "FWPSpeciesCountByYear",
    "endpoint": "http://localhost:3000/api/stored-proc",
    "http_method": "GET",
    "proc_params": {
      "from_year": "2024",
      "to_year": "2026"
    },
    "result_set_index": 0
  },
  "mapping": {
    "categoryField": "species",
    "valueField": "abundance",
    "labelTemplate": "{species} {year}"
  },
  "options": {
    "plugins": {
      "legend": {
        "position": "right"
      }
    }
  },
  "appearance": {
    "page_background": "linear-gradient(145deg, #d7e7df, #bfd6ce)",
    "card_background": "rgba(243,250,246,0.82)",
    "title_color": "#184f3f",
    "text_color": "#2f6f5d",
    "grid_color": "rgba(24,79,63,0.2)",    "x_axis_label_color": "#184f3f",
    "x_axis_value_color": "#2f6f5d",
    "y_axis_label_color": "#184f3f",
    "y_axis_value_color": "#2f6f5d",
    "legend_text_color": "#184f3f",    "series_colors": ["#4e79a7", "#f28e2b", "#59a14f", "#e15759", "#af7aa1"]
  }
}
