{
  "request_version": "1.0",
  "output": {
    "format": "html",
    "container_id": "chart-root"
  },
  "chart": {
    "type": "scatter",
    "title": "Length vs Weight Scatter",
    "show_legend": true,
    "x_axis_label": "Length (mm)",
    "y_axis_label": "Weight (g)"
  },
  "data_source": {
    "proc_schema": "ri",
    "proc_name": "FWPSectionSpeciesLengthWeightScatterByYear",
    "endpoint": "http://localhost:3000/api/stored-proc",
    "http_method": "GET",
    "proc_params": {
      "year": 2026,
      "section": "Bighorn Section (Upper)",
      "species": "RB"
    },
    "result_set_index": 0
  },
  "mapping": {
    "xField": "length",
    "yField": "weight"
  },
  "options": {
    "pointRadius": 3
  }
}
